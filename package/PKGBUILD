# Maintainer: Aidan <notsetupyet@i3x.xyz>
pkgname=qtcarbonated-shell
pkgver=1.0.0
pkgrel=1
pkgdesc="Qt-based shell for Hyprland, designed for usability."
arch=('x86_64')
url="https://github.com/aidanfromtheinternet/qtcarbonated"
license=('MIT')
depends=(
    'gcc-libs'
    'paru'
)
makedepends=('cargo')

source=("${pkgname}::git+https://github.com/aidanfromtheinternet/qtcarbonated.git#branch=main")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/${pkgname}"
    cargo build --release --locked
}

package() {
    cd "${srcdir}/${pkgname}"
    install -Dm755 "target/release/qtc" "${pkgdir}/usr/bin/qtc"
}
